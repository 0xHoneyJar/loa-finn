# deploy/staging.env.example — Staging (armitage) environment variables
# This file documents all environment variables needed for the staging deployment.
# Copy to .env and fill in secrets, or set via SSM Parameter Store.
#
# Variables marked "Set via SSM" are sourced from /loa-finn/armitage/* at deploy time.
# Variables marked "intentionally absent" are NOT needed in staging.

# --- Core ---
NODE_ENV=production
PORT=3000
HOST=0.0.0.0
DATA_DIR=/data

# --- Routing ---
# FINN_REPUTATION_ROUTING is the single source of truth for routing mode.
# (ROUTING_MODE is a legacy alias; if both are set, FINN_REPUTATION_ROUTING wins)
FINN_REPUTATION_ROUTING=shadow
X402_SETTLEMENT_MODE=verify_only

# --- Goodhart (shadow mode defaults) ---
FINN_EXPLORATION_EPSILON=0.05
# DIXIE_BASE_URL — intentionally absent; DixieStubTransport used in staging
# FINN_CALIBRATION_BUCKET_NAME — intentionally absent; graceful degrade to NoopCalibrationEngine

# --- Auth ---
FINN_S2S_JWT_ALG=ES256
FINN_AUTH_TOKEN=                    # Set via SSM: /loa-finn/armitage/FINN_AUTH_TOKEN

# --- Redis ---
# Staging uses shared ElastiCache with prefix isolation (logical DB 1 + key prefix)
REDIS_URL=                          # Set via SSM: /loa-finn/armitage/REDIS_URL
FINN_REDIS_PREFIX=armitage:
FINN_REDIS_DB=1

# --- Model Providers ---
ANTHROPIC_API_KEY=                  # Set via SSM: /loa-finn/armitage/ANTHROPIC_API_KEY

# --- Tracing ---
OTLP_ENDPOINT=http://tempo.arrakis.local:4317
